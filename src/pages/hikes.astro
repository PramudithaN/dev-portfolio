---
import Layout from '@/layouts/Layout.astro'
import PageHead from '@/components/PageHead.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { Icon } from 'astro-icon/components'

const currentUrl = Astro.url;

// Hiking destinations in Sri Lanka
const hikes = [
  {
    id: 'pekoe-trail-1',
    name: 'Pekoe Trail Stage 1',
    location: 'Hanthana to Galaha',
    lat: 7.2530,
    lng: 80.6380,
    description: 'A beautiful trek starting from Kandy through the historic Hanthana tea estates, offering lush green landscapes and stunning panoramic views of the surrounding valleys.',
    image: '/Images/pekoe.webp',
    type: 'Trail Hike',
    elevation: '1,150 m',
    difficulty: 'Moderate'
  },
  {
    id: 'knuckles',
    name: 'Knuckles Mountain Range',
    location: 'Matale / Kandy',
    lat: 7.4286,
    lng: 80.7750,
    description: 'A UNESCO World Heritage site named after its knuckle-shaped folds. Known for its rich biodiversity, cloud forests, and challenging trails through mist-shrouded peaks.',
    image: '/Images/knuckless.webp',
    type: 'Mountain Range',
    elevation: '1,863 m',
    difficulty: 'Hard'
  },
  {
    id: 'meemure',
    name: 'Meemure Village',
    location: 'Knuckles Range Boundary',
    lat: 7.4333,
    lng: 80.8389,
    description: 'One of the most isolated traditional villages in Sri Lanka. Surrounded by towering rock cliffs, pristine streams, and famous for its natural water slides.',
    image: '/Images/meemure.webp',
    type: 'Village Exploration',
    elevation: '1,310 m (Surrounding)',
    difficulty: 'Moderate'
  },
  {
    id: 'bambaragalapathana',
    name: 'Bambaragalapathana Camping',
    location: 'Deanston, Knuckles',
    lat: 7.3719,
    lng: 80.8406,
    description: 'An exceptional campsite overlooking the Knuckles valley. Pitching a tent here rewards you with beautiful sunrise views and stargazing opportunities.',
    image: '/Images/bambaragalapathana.webp',
    type: 'Camping & Hike',
    elevation: '1,100 m',
    difficulty: 'Moderate'
  },
  {
    id: 'wangedigala',
    name: 'Wangedigala Camping',
    location: 'Kalupahana, Haputale',
    lat: 6.7878,
    lng: 80.8122,
    description: 'A popular and steep hike through pine forests leading to a rocky ridge. Camping at the summit offers cold night winds, misty mornings, and views of Bambarakanda Falls.',
    image: '/Images/wangedigala.webp',
    type: 'Camping & Peak',
    elevation: '1,430 m',
    difficulty: 'Moderate'
  },
  {
    id: 'kirigalpoththa',
    name: 'Kirigalpoththa Hiking',
    location: 'Horton Plains',
    lat: 6.7997,
    lng: 80.7686,
    description: 'The second highest mountain in Sri Lanka (2,388m). The trail goes through Horton Plains grasslands, boggy marshes, and cloud forests, ending with a steep climb on a rocky ridge.',
    image: '/Images/kirigalpoththa.webp',
    type: 'Alpine Hike',
    elevation: '2,388 m',
    difficulty: 'Hard'
  }
];
---

<Layout canonicalUrl={currentUrl}>
  <Fragment slot="head">
    <PageHead title="Hiking Map & Expeditions | Pramuditha Nadun" description="Explore an interactive map of my hiking, peak summit, and camping expeditions across Sri Lanka." />
    <!-- Leaflet JS & CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>
  </Fragment>

  <Breadcrumbs
    items={[
      { label: 'Hikes', href: '/hikes', icon: 'lucide:mountain' },
    ]}
  />

  <section class="max-w-screen-xl mx-auto mt-6 px-4 md:px-6">
    <div class="mb-8">
      <div class="flex w-fit items-center gap-2 text-primary">
        <Icon name="lucide:map" class="h-4 w-4 text-primary animate-pulse" />
        <p class="word-spacing font-mono text-sm uppercase leading-none text-primary">My Expeditions</p>
      </div>
      <h1 class="font-custom text-foreground text-4xl font-bold mt-2">Hiking Map & Gallery</h1>
      <p class="text-muted-foreground text-md max-w-2xl mt-3">
        An interactive journey through my treks, peaks, and campsites across Sri Lanka. Click on any location card or map marker to explore details.
      </p>
    </div>

    <!-- Main Content Split Dashboard -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start mb-12">
      
      <!-- Left: Scrollable Hikes List -->
      <div class="lg:col-span-5 flex flex-col gap-4 overflow-y-auto lg:max-h-[calc(100vh-14rem)] pr-2 scrollbar-thin">
        {hikes.map(hike => (
          <div
            data-hike-id={hike.id}
            class="group cursor-pointer bg-card hover:bg-accent/5 border border-border hover:border-primary/30 rounded-xl p-4 shadow-md transition-all duration-300 flex gap-4"
          >
            <div class="relative w-24 h-24 sm:w-28 sm:h-28 rounded-lg overflow-hidden shrink-0">
              <img src={hike.image} alt={hike.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <span class="absolute top-2 left-2 bg-black/60 backdrop-blur-sm text-primary-foreground text-[10px] font-semibold px-2 py-0.5 rounded-full border border-white/10">
                {hike.type}
              </span>
            </div>
            
            <div class="flex flex-col justify-between py-1">
              <div>
                <h3 class="font-semibold text-base sm:text-lg text-foreground group-hover:text-primary transition-colors line-clamp-1">{hike.name}</h3>
                <p class="text-xs text-muted-foreground flex items-center gap-1 mt-0.5">
                  <Icon name="lucide:map-pin" class="h-3 w-3" />
                  {hike.location}
                </p>
                <p class="text-xs text-muted-foreground/80 mt-2 line-clamp-2">{hike.description}</p>
              </div>
              
              <div class="flex gap-3 mt-2 flex-wrap text-[11px]">
                <span class="text-foreground/90 font-medium flex items-center gap-1">
                  <Icon name="lucide:trending-up" class="h-3 w-3 text-emerald-500" />
                  {hike.elevation}
                </span>
                <span class={`font-medium px-2 py-0.5 rounded-full text-[10px] border ${
                  hike.difficulty === 'Hard' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                  hike.difficulty === 'Moderate' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20' :
                  'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
                }`}>
                  {hike.difficulty}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: Map Dashboard -->
      <div class="lg:col-span-7 h-[350px] sm:h-[500px] lg:h-[calc(100vh-14rem)] lg:sticky lg:top-24 rounded-2xl overflow-hidden border border-border shadow-lg relative bg-black">
        <div id="map" class="w-full h-full"></div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  /* Custom scrollbar for list */
  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background-color: rgba(156, 163, 175, 0.2);
    border-radius: 9999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background-color: rgba(156, 163, 175, 0.4);
  }

  /* Custom marker styles */
  .custom-marker {
    background: transparent !important;
    border: none !important;
  }

  /* Custom leaflet adjustments */
  .leaflet-container {
    background: #09090b !important;
    font-family: inherit !important;
  }
  .leaflet-popup-content-wrapper {
    background: #18181b !important;
    color: #f4f4f5 !important;
    border: 1px solid #27272a;
    border-radius: 0.75rem !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5) !important;
    padding: 0.25rem !important;
  }
  .leaflet-popup-tip {
    background: #18181b !important;
    border: 1px solid #27272a;
  }
  .leaflet-popup-content {
    margin: 8px 12px !important;
    line-height: 1.4 !important;
  }
  .leaflet-container a.leaflet-popup-close-button {
    color: #a1a1aa !important;
    top: 4px !important;
    right: 4px !important;
    padding: 4px 6px 0 0 !important;
  }
  .leaflet-container a.leaflet-popup-close-button:hover {
    color: #f4f4f5 !important;
    background: transparent !important;
  }
  .leaflet-bar {
    border: 1px solid #27272a !important;
    box-shadow: none !important;
    border-radius: 0.5rem !important;
    overflow: hidden;
  }
  .leaflet-bar a {
    background-color: #18181b !important;
    color: #f4f4f5 !important;
    border-bottom: 1px solid #27272a !important;
  }
  .leaflet-bar a:hover {
    background-color: #27272a !important;
    color: #ffffff !important;
  }
  .leaflet-bar a:first-child {
    border-top-left-radius: 0.5rem !important;
    border-top-right-radius: 0.5rem !important;
  }
  .leaflet-bar a:last-child {
    border-bottom-left-radius: 0.5rem !important;
    border-bottom-right-radius: 0.5rem !important;
    border-bottom: none !important;
  }
</style>

<script define:vars={{ hikes }} is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof L === 'undefined') {
      console.error('Leaflet is not defined. Checking again in 500ms...');
      setTimeout(initializeMap, 500);
      return;
    }
    initializeMap();

    function initializeMap() {
      // Coordinates of central hill country in Sri Lanka
      const map = L.map('map', {
        center: [7.18, 80.77],
        zoom: 9,
        zoomControl: false
      });

      // Add zoom control bottom right
      L.control.zoom({ position: 'bottomright' }).addTo(map);

      // CartoDB Dark Matter tile layer
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);

      // Custom marker icon HTML
      const markerHtml = `
        <div class="relative flex items-center justify-center w-6 h-6">
          <span class="absolute inline-flex h-6 w-6 animate-ping rounded-full bg-primary/30 opacity-75"></span>
          <span class="relative inline-flex h-3.5 w-3.5 rounded-full bg-primary border-2 border-background shadow-md"></span>
        </div>
      `;

      const customIcon = L.divIcon({
        html: markerHtml,
        className: 'custom-marker',
        iconSize: [24, 24],
        iconAnchor: [12, 12]
      });

      const markers = {};

      // Add markers
      hikes.forEach(hike => {
        const popupContent = `
          <div class="p-1">
            <h4 class="font-bold text-sm text-foreground font-custom">${hike.name}</h4>
            <p class="text-xs text-muted-foreground mt-0.5 flex items-center gap-1">
              <span>📍</span> ${hike.location}
            </p>
            <div class="flex gap-2 mt-2">
              <span class="bg-primary/20 text-primary rounded-full px-2 py-0.5 text-[9px] font-semibold border border-primary/20">${hike.type}</span>
              <span class="text-foreground/90 text-[10px] font-medium font-mono">${hike.elevation}</span>
            </div>
          </div>
        `;

        const marker = L.marker([hike.lat, hike.lng], { icon: customIcon })
          .addTo(map)
          .bindPopup(popupContent);

        markers[hike.id] = marker;

        // Sync marker click -> highlight card
        marker.on('click', () => {
          highlightCard(hike.id);
        });
      });

      // Sync card click -> pan map & open popup
      const cards = document.querySelectorAll('[data-hike-id]');
      cards.forEach(card => {
        card.addEventListener('click', () => {
          const id = card.getAttribute('data-hike-id');
          const hike = hikes.find(h => h.id === id);
          if (hike) {
            map.setView([hike.lat, hike.lng], 11, {
              animate: true,
              duration: 1.2
            });
            markers[id].openPopup();
            highlightCard(id);
          }
        });
      });

      function highlightCard(id) {
        cards.forEach(c => {
          if (c.getAttribute('data-hike-id') === id) {
            c.classList.add('border-primary', 'bg-primary/[0.03]');
            c.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          } else {
            c.classList.remove('border-primary', 'bg-primary/[0.03]');
          }
        });
      }
    }
  });
</script>
