---
// src/pages/landing.astro
import { Button } from '@/components/ui/button';
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
const currentUrl = Astro.url;
---

<Layout canonicalUrl={currentUrl}>
  <head slot="head">
    <title>Pramuditha Nadun | AI Research Portfolio</title>
    <meta name="description" content="Final year AI researcher focusing on explainable deep learning models for crude oil price prediction. Explore my research projects and technical expertise." />
    <!-- Importing fonts from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@700;900&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <main
    class="page-container fixed top-0 left-0 w-screen h-screen overflow-hidden bg-black"
  >
    <!-- Layer for the overlapping images -->
    <div class="image-layers absolute inset-0 z-10">
      <!-- Designer layers (Bottom layers, revealed when developer container is clipped) -->
      <div class="designer-hero-container absolute inset-0 overflow-hidden pointer-events-none">
        <div class="image-bg des-bg-layer"></div>
        <div class="image-bg des-char-layer"></div>
      </div>
      
      <!-- Developer layers (Top layers, clipped based on mouse cursor position) -->
      <div class="developer-hero-container absolute inset-0 overflow-hidden pointer-events-none">
        <div class="image-bg dev-bg-layer"></div>
        <div class="image-bg dev-char-layer"></div>
      </div>
    </div>

    <!-- Central Name/Logo -->
    <div
      class="central-logo absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 text-center pointer-events-none"
    >
          <h2
          class=" text-white text-2xl md:text-3xl font-bold tracking-wider"
          style="font-family: 'ClashDisplay-Semibold'"
      >
        PRAMUDITHA
      </h2>
      <p class="text-white/70 text-sm">AI Researcher & Associate Software Engineer</p>
    </div>

    <!-- Interaction Layer (sits on top of everything) -->
    <div class="interaction-layer absolute inset-0 z-30 flex">
      <!-- Left Section Link (Transparent Hover Target) -->
      <a href="/designer" class="group section-link designer-section">
        <div class="content">
         <h1 class="title" style="color: #fff !important; font-family: 'ClashDisplay-Semibold', sans-serif;">DESIGNER</h1>
          <span class="cta">
          View as Designer
          <span class="arrow">&rarr;</span>
          </span>
        </div>
      </a>
      <!-- Right Section Link (Transparent Hover Target) -->
      <a href="/developer" class="group section-link coder-section hidden md:flex">
        <div class="content">
          <h1 class="title font-mono" style="color: #fff !important">&lt;DEVELOPER&gt;</h1>
          <span class="cta">
        View as Developer
        <span class="arrow">&rarr;</span>
          </span>
        </div>
      </a>

      <!-- Mobile: Show both buttons under the title/role -->
      <div class="md:hidden absolute left-1/2 top-[calc(60%+2rem)] -translate-x-1/2 flex gap-4 z-30">
        <a href="/designer" class="group">
          <Button variant="outline" className="font-bold px-6 py-2">
        DESIGNER
          </Button>
        </a>
        <a href="/developer" class="group">
          <Button variant="outline" className="font-bold px-6 py-2">
        &lt;DEVELOPER&gt;
          </Button>
        </a>
      </div>

      <!-- Hide the main section links on mobile -->
      <style>
        @media (max-width: 767px) {
          .designer-section,
          .coder-section {
        display: none !important;
          }
        }
      </style>
    </div>

    <!-- Social Media Icons -->
       <div class="social-icons absolute bottom-8 left-1/2 -translate-x-1/2 z-40 flex gap-6">
        <!-- Github -->
         <a
          href={`https://github.com/PramudithaN`}
          target="_blank"
          rel="noopener noreferrer"
          title="Github"
          aria-label="Github"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="line-md:github" class="size-4" />
          </Button>
        </a>

        <!-- LinkedIn -->
        <a
          href={`http://www.linkedin.com/in/pramuditha-nadun-612b1b204`}
          target="_blank"
          rel="noopener noreferrer"
          title="LinkedIn"
          aria-label="LinkedIn"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="line-md:linkedin" class="size-4" />
          </Button>
        </a>

        <!-- Behance -->
        <!-- <a
          href={`https://www.behance.net/pramudithanadun1`}
          target="_blank"
          rel="noopener noreferrer"
          title="Behance"
          aria-label="Behance"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="simple-icons:behance" class="size-4" /> 
            <svg xmlns="http://www.w3.org/2000/svg" class="icon-svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <rect width="20" height="20" x="2" y="2" rx="4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M8 15v-6h3a2 2 0 0 1 0 4H8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M16 15a2 2 0 0 0 0-4c-1.1 0-2 .9-2 2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14 12h4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
          </Button>
        </a> -->

        <!-- Whatsapp -->
        <a
            href="https://wa.me/94767405824"
          target="_blank"
          rel="noopener noreferrer"
          title="WhatsApp"
          aria-label="WhatsApp"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="mdi:whatsapp" class="size-4" />
          </Button>
        </a>

        <!-- Instagram -->
        <a
          href={`https://www.instagram.com/pramx.psd?igsh=MWNtaXF2cWw2ajEwcg==`}
          target="_blank"
          rel="noopener noreferrer"
          title="Instagram"
          aria-label="Instagram"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="line-md:instagram" class="size-4" />
          </Button>
        </a>

        <!-- Pinterest -->
        <a
          href={`https://pin.it/Lb92N4TnM`}
          target="_blank"
          rel="noopener noreferrer"
          title="Pinterest"
          aria-label="Pinterest"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="mdi:pinterest" class="size-4" />
          </Button>
        </a>

         <!-- Facebook -->
        <a
          href={`https://web.facebook.com/pramuditha.nadun`}
          target="_blank"
          rel="noopener noreferrer"
          title="Facebook"
          aria-label="Facebook"
        >
          <Button variant="outline" className='cursor-pointer' size="icon">
            <Icon name="line-md:facebook" class="size-4" />
          </Button>
        </a>
      </div>
      </a>
    </div>

    <style>
      .social-icons {
        background: rgba(0,0,0,0.6);
        padding: 0.5rem 1.5rem;
        border-radius: 9999px;
        box-shadow: 0 2px 16px 0 rgba(0,0,0,0.2);
        backdrop-filter: blur(6px);
      }
      .icon-link {
        color: #fff;
        opacity: 0.8;
        transition: color 0.2s, opacity 0.2s, transform 0.2s;
        display: flex;
        align-items: center;
      }
      .icon-link:hover {
        color: #38bdf8;
        opacity: 1;
        transform: translateY(-2px) scale(1.08);
      }
      .icon-svg {
        display: block;
        width: 28px;
        height: 28px;
      }
    </style>
  </main>

  <style>
    /* Custom fonts */
    .font-custom {
      font-family: 'Poppins', sans-serif;
    }
    .font-mono {
      font-family: 'Space Mono', monospace;
    }

    /* Base styles for the image layers */
    .image-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      background-size: cover;
      background-position: center;
      /* Smooth GPU transforms for parallax motion */
      transform: scale(1.08) translate3d(var(--tx, 0px), var(--ty, 0px), 0);
      will-change: transform;
    }

    /* Designer Containers & Layers */
    .designer-hero-container {
      position: absolute;
      inset: 0;
      z-index: 1;
    }
    
    .des-bg-layer {
      background-image: linear-gradient(rgba(0,0,0,0.15), rgba(0,0,0,0.15)), url('/Images/des_bg.webp');
      z-index: 1;
    }
    
    .des-char-layer {
      background-image: url('/Images/des-c.webp');
      z-index: 2;
    }

    /* Developer Containers & Layers */
    .developer-hero-container {
      position: absolute;
      inset: 0;
      z-index: 2;
      /* CORE LOGIC: Initially show only the left 50% of this top container */
      clip-path: inset(0 50% 0 0);
      /* Add transition for the reset animation on mouseleave */
      transition: clip-path 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    }
    
    .dev-bg-layer {
      background-image: linear-gradient(rgba(0,0,0,0.15), rgba(0,0,0,0.15)), url('/Images/dev_bg.webp');
      z-index: 1;
    }
    
    .dev-char-layer {
      background-image: url('/Images/dev-c.webp');
      z-index: 2;
    }
    /* --- End of important section --- */


    /* Interaction links styling (Transparent hover targets) */
    .section-link {
      display: flex;
      justify-content: center;
      align-items: center;
      flex: 1; /* Each link takes up 50% of the space */
      text-decoration: none;
      height: 100%;
      position: relative;
    }

    /* CSS hover animations for clip-path have been removed */

    /* Content wrapper inside the link */
    .content {
      text-align: center;
      color: white;
      position: relative;
      z-index: 1;
      /* Initial state for the animation */
      opacity: 0;
      transform: scale(0.95);
      transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    }
    
    /* Reveal content on hover */
    .section-link:hover .content {
        opacity: 1;
        transform: scale(1);
        transition-delay: 0.2s; 
    }


    /* Main title styles */
    .title {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 900;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* "Call to Action" text styles */
    .cta {
      display: inline-block;
      margin-top: 1rem;
      font-size: 1.125rem;
      color: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 0.5rem 1.5rem;
      border-radius: 9999px;
      transition: all 0.4s ease;
      backdrop-filter: blur(5px);
    }

    .group:hover .cta {
      background-color: white;
      color: black;
      border-color: white;
    }

    /* Arrow styling */
    .arrow {
      display: inline-block;
      margin-left: 0.5rem;
      transition: transform 0.4s ease;
    }

    .group:hover .arrow {
      transform: translateX(5px);
    }

    /* Central logo fade on hover */
    .central-logo {
        transition: opacity 0.5s ease;
    }
    .interaction-layer:hover ~ .central-logo {
        opacity: 0;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const devContainer: HTMLElement | null = document.querySelector('.developer-hero-container');
      const desBg: HTMLElement | null = document.querySelector('.des-bg-layer');
      const desChar: HTMLElement | null = document.querySelector('.des-char-layer');
      const devBg: HTMLElement | null = document.querySelector('.dev-bg-layer');
      const devChar: HTMLElement | null = document.querySelector('.dev-char-layer');
      const pageContainer: HTMLElement | null = document.querySelector('.page-container');
      
      if (!devContainer || !pageContainer) return;

      // Parallax intensities (max translation in pixels)
      const bgIntensity = 12;
      const charIntensity = 28;
      
      // A smaller value creates a more noticeable delay/smoothing effect.
      const lerpFactor = 0.05; 

      let targetX = window.innerWidth / 2;
      let targetY = window.innerHeight / 2;
      let currentX = window.innerWidth / 2;
      let currentY = window.innerHeight / 2;
      let isMouseOver = false;

      // --- 1. Animation Loop ---
      function animate() {
        if (!isMouseOver) {
          targetX = window.innerWidth / 2;
          targetY = window.innerHeight / 2;
        }

        // Lerp for smooth motion
        currentX += (targetX - currentX) * lerpFactor;
        currentY += (targetY - currentY) * lerpFactor;

        // --- 2. Reveal Logic ---
        const clipPercentage = (currentX / window.innerWidth) * 100;
        if (devContainer) {
          devContainer.style.transition = isMouseOver ? 'none' : 'clip-path 0.5s cubic-bezier(0.23, 1, 0.32, 1)';
          devContainer.style.clipPath = `inset(0 ${100 - clipPercentage}% 0 0)`;
        }

        // --- 3. Parallax Logic ---
        const ndcX = (currentX / window.innerWidth) - 0.5;
        const ndcY = (currentY / window.innerHeight) - 0.5;

        // Calculate translation values (moving opposite to mouse direction for depth)
        const bgTx = -ndcX * bgIntensity;
        const bgTy = -ndcY * bgIntensity;
        const charTx = -ndcX * charIntensity;
        const charTy = -ndcY * charIntensity;

        // Set CSS Custom Properties for high-performance transforms
        if (desBg) {
          desBg.style.setProperty('--tx', `${bgTx}px`);
          desBg.style.setProperty('--ty', `${bgTy}px`);
        }
        if (desChar) {
          desChar.style.setProperty('--tx', `${charTx}px`);
          desChar.style.setProperty('--ty', `${charTy}px`);
        }
        if (devBg) {
          devBg.style.setProperty('--tx', `${bgTx}px`);
          devBg.style.setProperty('--ty', `${bgTy}px`);
        }
        if (devChar) {
          devChar.style.setProperty('--tx', `${charTx}px`);
          devChar.style.setProperty('--ty', `${charTy}px`);
        }
        
        requestAnimationFrame(animate);
      }
      
      // --- 4. Event Listeners ---
      pageContainer.addEventListener('mousemove', (e: MouseEvent) => {
        targetX = e.clientX;
        targetY = e.clientY;
      });
      
      pageContainer.addEventListener('mouseenter', () => {
        isMouseOver = true;
      });

      pageContainer.addEventListener('mouseleave', () => {
        isMouseOver = false;
      });

      // Start the animation loop
      animate();
    });
  </script>
</Layout>
