---
interface Props {
  type?: 'stars' | 'coding';
}
const { type = 'stars' } = Astro.props;
---
<div class="fixed inset-0 -z-40 pointer-events-none overflow-hidden" aria-hidden="true">
  <canvas id="bg-canvas" class="w-full h-full block" data-type={type}></canvas>
</div>

<script>
  class BackgroundAnimation {
    canvas!: HTMLCanvasElement;
    ctx!: CanvasRenderingContext2D;
    particles: Array<{
      x: number;
      y: number;
      radius: number;
      vx: number;
      vy: number;
      alpha: number;
      glow: number;
      glowDir: number;
    }> = [];
    animationFrameId: number | null = null;
    width: number = 0;
    height: number = 0;
    isDark: boolean = false;
    observer: MutationObserver | null = null;
    type: 'stars' | 'coding' = 'stars';
    columns: Array<{
      x: number;
      rowOffset: number;
      stepInterval: number;
      lastStepTime: number;
      snippet: string;
      trailLength: number;
    }> = [];

    constructor() {
      this.canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
      if (!this.canvas) return;
      this.ctx = this.canvas.getContext('2d')!;
      this.particles = [];
      this.animationFrameId = null;
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.isDark = document.documentElement.classList.contains('dark');
      this.observer = null;

      this.init();
      this.animate();

      window.addEventListener('resize', this.handleResize.bind(this));

      // Observe theme changes
      this.observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.attributeName === 'class') {
            const currentDark = document.documentElement.classList.contains('dark');
            if (currentDark !== this.isDark) {
              this.isDark = currentDark;
              this.init();
            }
          }
        });
      });
      this.observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
      });
    }

    init() {
      this.type = (this.canvas.dataset.type as 'stars' | 'coding') || 'stars';
      this.canvas.width = this.width;
      this.canvas.height = this.height;
      if (this.type === 'coding') {
        this.initCoding();
      } else {
        this.initStars();
      }
    }

    initStars() {
      this.particles = [];
      const particleCount = this.isDark ? 55 : 30; // Subtle density
      for (let i = 0; i < particleCount; i++) {
        this.particles.push(this.createParticle());
      }
    }

    initCoding() {
      this.columns = [];
      const spacing = 18; // Spacing between columns
      const fontSize = 12; // Font size for coding text
      const colCount = Math.ceil(this.width / spacing);

      const codeSnippets = [
        "const price = await predictPrice(model, data);",
        "import { LSTM, Dense } from '@/components/deep-learning';",
        "tf.layers.lstm({ units: 128, returnSequences: true })",
        "const loss = tf.losses.meanSquaredError(labels, predictions);",
        "model.fit(xTrain, yTrain, { epochs: 200, batchSize: 32 });",
        "export default async function trainModel(dataset) {",
        "const attention = selfAttention(query, key, value);",
        "return tf.tidy(() => { const y = model.predict(x); });",
        "const shapValues = explainModel(lstmModel, inputData);",
        "const currentTheme = document.documentElement.classList.contains('dark');",
        "function explainPredictions(shapValues) { return shapValues.map(v => v.abs()); }",
        "const nextPrice = lstmCell.forward(inputFeature);",
        "const optimizer = tf.train.adam(learningRate);",
        "const [state, dispatch] = useReducer(reducer, initialState);",
        "export const getStaticProps: GetStaticProps = async (context) => {",
        "useEffect(() => { const sub = api.subscribe(); return () => sub.unsubscribe(); }, []);",
        "interface User { id: string; name: string; role: 'admin' | 'user'; }",
        "const response = await fetch(`/api/v1/users/${id}`);",
        "export default function App({ Component, pageProps }) {",
        "const queryClient = new QueryClient();",
        "const filtered = items.filter(item => item.active);"
      ];

      for (let i = 0; i < colCount; i++) {
        const snippet = codeSnippets[Math.floor(Math.random() * codeSnippets.length)];
        const trailLength = Math.floor(Math.random() * 8) + 6; // 6 to 14 characters

        this.columns.push({
          x: i * spacing,
          rowOffset: Math.floor(Math.random() * (this.height / fontSize + 10)) - 10,
          stepInterval: Math.random() * 150 + 100, // 100ms to 250ms per step
          lastStepTime: performance.now() - Math.random() * 1000,
          snippet,
          trailLength
        });
      }
    }

    createParticle() {
      return {
        x: Math.random() * this.width,
        y: Math.random() * this.height,
        radius: this.isDark ? Math.random() * 1.2 + 0.6 : Math.random() * 1.8 + 0.8,
        vx: this.isDark 
          ? (Math.random() - 0.5) * 0.12 
          : (Math.random() > 0.5 ? (Math.random() * 0.1 + 0.04) : 0),
        vy: this.isDark 
          ? (Math.random() - 0.5) * 0.12 
          : (Math.random() > 0.5 ? 0 : (Math.random() * 0.1 + 0.04)),
        alpha: Math.random() * 0.4 + 0.2,
        glow: Math.random() * 0.008 + 0.002,
        glowDir: Math.random() > 0.5 ? 1 : -1
      };
    }

    handleResize() {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.init();
    }

    animate() {
      this.ctx.clearRect(0, 0, this.width, this.height);
      if (this.type === 'coding') {
        this.drawCoding(performance.now());
      } else {
        this.draw();
      }
      this.animationFrameId = requestAnimationFrame(this.animate.bind(this));
    }

    drawCoding(now: number) {
      this.ctx.font = '12px "Space Mono", "Courier New", monospace';
      this.ctx.textBaseline = 'top';
      const fontSize = 12;
      const totalRows = Math.ceil(this.height / fontSize);
      const isDarkTheme = this.isDark;

      for (let i = 0; i < this.columns.length; i++) {
        const col = this.columns[i];

        // Update row position based on stepInterval
        if (now - col.lastStepTime > col.stepInterval) {
          col.rowOffset++;
          col.lastStepTime = now;

          // If the trail has fully moved off screen, reset the column
          if (col.rowOffset - col.trailLength > totalRows) {
            col.rowOffset = -Math.floor(Math.random() * 10) - 2;
            col.stepInterval = Math.random() * 150 + 100;
            col.trailLength = Math.floor(Math.random() * 8) + 6;
          }
        }

        // Draw the characters in the trail
        for (let j = 0; j < col.trailLength; j++) {
          const r = col.rowOffset - j;
          const charY = r * fontSize;

          if (charY > -fontSize && charY < this.height) {
            const charIndex = r % col.snippet.length;
            const safeIndex = charIndex >= 0 ? charIndex : (col.snippet.length + (charIndex % col.snippet.length)) % col.snippet.length;
            const char = col.snippet[safeIndex];

            const fraction = j / col.trailLength;
            const opacity = (1 - fraction) * (isDarkTheme ? 0.08 : 0.09);

            if (j === 0) {
              // Head character: subtle highlight
              this.ctx.fillStyle = isDarkTheme 
                ? `rgba(165, 243, 252, ${opacity * 1.5})` 
                : `rgba(15, 23, 42, ${opacity * 1.6})`;
            } else {
              // Trail character: fading
              this.ctx.fillStyle = isDarkTheme 
                ? `rgba(34, 211, 238, ${opacity})` 
                : `rgba(59, 130, 246, ${opacity})`;
            }

            this.ctx.fillText(char, col.x, charY);
          }
        }
      }
    }

    draw() {
      const isDarkTheme = this.isDark;
      const particleColor = isDarkTheme ? '255, 255, 255' : '9, 9, 11';
      const lineColor = isDarkTheme ? '255, 255, 255' : '9, 9, 11';

      this.particles.forEach((p, index) => {
        // Update positions
        p.x += p.vx;
        p.y += p.vy;

        // Wrap boundaries
        if (p.x < 0) p.x = this.width;
        if (p.x > this.width) p.x = 0;
        if (p.y < 0) p.y = this.height;
        if (p.y > this.height) p.y = 0;

        // Pulsing alphas
        p.alpha += p.glow * p.glowDir;
        if (p.alpha > 0.75 || p.alpha < 0.15) {
          p.glowDir *= -1;
        }

        // Draw node
        this.ctx.beginPath();
        this.ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        this.ctx.fillStyle = `rgba(${particleColor}, ${p.alpha * (isDarkTheme ? 0.4 : 0.25)})`;
        this.ctx.fill();

        if (!isDarkTheme) {
          // Light Mode - Grid Guidelines
          this.ctx.beginPath();
          this.ctx.strokeStyle = `rgba(${lineColor}, 0.012)`;
          this.ctx.lineWidth = 0.4;
          
          this.ctx.moveTo(0, p.y);
          this.ctx.lineTo(this.width, p.y);
          this.ctx.moveTo(p.x, 0);
          this.ctx.lineTo(p.x, this.height);
          
          this.ctx.stroke();
        }

        // Draw connections
        for (let j = index + 1; j < this.particles.length; j++) {
          const p2 = this.particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          const maxDist = isDarkTheme ? 120 : 140;

          if (dist < maxDist) {
            const alpha = (1 - dist / maxDist) * (isDarkTheme ? 0.05 : 0.035);
            this.ctx.beginPath();
            this.ctx.strokeStyle = `rgba(${lineColor}, ${alpha})`;
            this.ctx.lineWidth = isDarkTheme ? 0.4 : 0.3;
            this.ctx.moveTo(p.x, p.y);
            this.ctx.lineTo(p2.x, p2.y);
            this.ctx.stroke();
          }
        }
      });
    }

    destroy() {
      if (this.animationFrameId) {
        cancelAnimationFrame(this.animationFrameId);
      }
      if (this.observer) {
        this.observer.disconnect();
      }
    }
  }

  let bgAnimation: BackgroundAnimation | null = null;

  function initBg() {
    if (bgAnimation) {
      bgAnimation.destroy();
    }
    bgAnimation = new BackgroundAnimation();
  }

  document.addEventListener('DOMContentLoaded', initBg);
  document.addEventListener('astro:after-swap', initBg);
</script>
